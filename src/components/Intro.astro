---
import SectionBackground from './SectionBackground.astro';

interface IntroContent {
	titleStart: string;
	titleHighlight: string;
	tagline: string;
	subline: string;
}

interface Props {
	content: IntroContent;
	backgroundImage: string;
}

const { content, backgroundImage } = Astro.props;
---

<section id="hero" class="relative isolate overflow-hidden py-20 md:py-28">
	<SectionBackground
	image={backgroundImage}
	alt="background image"
	overlayClass="bg-white/70 dark:bg-black/60"
/>

	<div class="mx-auto w-full max-w-[1600px] px-4 sm:px-6 lg:px-10 text-gray-900 dark:text-white">
		<h2 class="text-center text-4xl md:text-5xl font-bold">
			{content.titleStart} <span class="text-brand">{content.titleHighlight}</span>
		</h2>
		<div class="mx-auto mt-4 h-1.5 w-28 bg-brand"></div>

		<div class="mx-auto mt-8 max-w-3xl text-center md:mt-10 lg:max-w-4xl">
			<p class="text-xl text-brand-muted font-bold leading-snug tracking-tight text-balance md:text-2xl lg:text-3xl">
				{content.tagline}
			</p>
			<p class="hero-intro-sub mt-3 text-sm leading-relaxed text-balance opacity-80 md:text-base lg:text-lg">
				{content.subline}
			</p>
		</div>
	</div>
</section>

<style>
	@keyframes hero-tagline-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-hero-tagline-in {
		animation: hero-tagline-in 900ms ease-out 200ms both;
	}

	.hero-tagline,
	.hero-intro-sub {
		font-family: var(--font-body);
		text-wrap: balance;
	}

	@media (prefers-reduced-motion: reduce) {
		.animate-hero-tagline-in {
			animation: none;
		}
	}
</style>
