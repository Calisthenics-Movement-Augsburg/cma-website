---
import MapEmbed from './MapEmbed.astro';
import SectionBackground from './SectionBackground.astro';

interface TrainingCard {
	title: string;
	text: string;
}

interface TrainingInfoContent {
	title: string;
	intro: string;
	trainingCards: TrainingCard[];
	audience: {
		title: string;
		text: string;
	};
	bring: {
		title: string;
		items: string[];
	};
	location: {
		title: string;
		addressLabel: string;
		address: string;
		accessLabel: string;
		access: string;
		transportLabel: string;
		transport: string;
		mapAddress: string;
		mapsUrl: string;
	};
	cta: {
		title: string;
		text: string;
		label: string;
		href: string;
	};
}

interface Props {
	content: TrainingInfoContent;
	backgroundImage?: string;
}

const { content, backgroundImage } = Astro.props;
---

<section id="training-ablauf" class="relative isolate overflow-hidden py-20 md:py-28">
	<!-- {
		backgroundImage && (
			<SectionBackground
				image={backgroundImage}
				overlayClass="bg-white/70 dark:bg-black/60"
			/>
		)
	} -->

	<div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-10 text-gray-900 dark:text-white">
		<div class="text-center">
			<h2 class="text-4xl font-bold md:text-5xl">{content.title}</h2>
			<div class="mx-auto mt-4 h-1.5 w-28 bg-brand"></div>

			<p class="mx-auto mt-6 max-w-3xl text-base leading-relaxed opacity-85 md:text-lg">
				{content.intro}
			</p>
		</div>

		<div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
			{
				content.trainingCards.map((card) => (
					<article class="training-info-card rounded-2xl border p-6">
						<h3 class="text-2xl font-extrabold">{card.title}</h3>
						<p class="mt-3 text-sm leading-relaxed opacity-85">{card.text}</p>
					</article>
				))
			}
		</div>

		<div class="mt-14 grid gap-8 lg:grid-cols-2">
			<article class="training-info-card rounded-2xl border p-6 md:p-8">
				<h3 class="text-3xl font-extrabold">{content.audience.title}</h3>
				<p class="mt-5 text-base leading-relaxed opacity-90">
					{content.audience.text}
				</p>
			</article>

			<article class="training-info-card rounded-2xl border p-6 md:p-8">
				<h3 class="text-3xl font-extrabold">{content.bring.title}</h3>

				<ul class="mt-5 grid gap-3 text-base opacity-90">
					{
						content.bring.items.map((item) => (
							<li class="flex gap-3">
								<span class="text-brand font-black">•</span>
								<span>{item}</span>
							</li>
						))
					}
				</ul>
			</article>
		</div>

		<article class="training-info-card mt-8 rounded-2xl border p-6 md:p-8">
			<div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
				<div>
					<h3 class="text-3xl font-extrabold">{content.location.title}</h3>

					<div class="mt-5 space-y-4 text-base leading-relaxed opacity-90">
						<p>
							<strong>{content.location.addressLabel}:</strong><br />
							{content.location.address}
						</p>

						<p>
							<strong>{content.location.accessLabel}:</strong><br />
							{content.location.access}
						</p>

						<p>
							<strong>{content.location.transportLabel}:</strong><br />
							{content.location.transport}
						</p>
					</div>
				</div>

				<MapEmbed
					mapsUrl={content.location.mapsUrl}
				/>
			</div>
		</article>

		<div class="mt-14 text-center">
			<h3 class="text-3xl font-extrabold">{content.cta.title}</h3>

			<p class="mt-3 text-base opacity-85 md:text-lg">
				{content.cta.text}
			</p>

			<a
				class="mt-6 inline-flex items-center rounded-full bg-brand px-8 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-brand-muted"
				href={content.cta.href}
			>
				{content.cta.label}
			</a>
		</div>
	</div>
</section>