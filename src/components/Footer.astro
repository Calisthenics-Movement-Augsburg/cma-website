---

const currentYear = new Date().getFullYear();

const footerLinks = [
  { href: "/training", label: "Training" },
  { href: "/probetraining", label: "Probetraining" },
  { href: "/mitgliedschaft", label: "Mitgliedschaft" },
  { href: "/downloads", label: "Downloads" },
  { href: "/kontakt", label: "Kontakt" },
];

const legalLinks = [
  { href: "/impressum", label: "Impressum" },
  { href: "/datenschutz", label: "Datenschutz" },
];
---

<footer class="relative z-10 border-t border-white/10 bg-black/80 text-white backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-6 py-10 lg:px-8">
    <div class="grid gap-10 md:grid-cols-[1.3fr_1fr_1fr]">
      
      <!-- Verein / Mini-Impressum -->
      <section>
        <h2 class="text-lg font-bold uppercase tracking-wide">
          CMA e.V.
        </h2>

        <p class="mt-3 max-w-md text-sm leading-6 text-white/70">
          Calisthenics Movement Augsburg e.V.<br />
          Gemeinnütziger Sportverein für Calisthenics, Streetworkout und funktionelles Training in Augsburg.
        </p>

        <address class="mt-4 not-italic text-sm leading-6 text-white/70">
          CMA e.V.<br />
          Augsburg, Deutschland<br />
          E-Mail:
          <a
            href="mailto:info@cma-augsburg.de"
            class="text-white underline decoration-white/30 underline-offset-4 hover:decoration-white"
          >
            info@cma-augsburg.de
          </a>
        </address>

        <p class="mt-4 text-xs leading-5 text-white/50">
          Vertreten durch den Vorstand. Vollständige Angaben gemäß § 5 TMG findest du im
          <a
            href="/impressum"
            class="text-white underline decoration-white/30 underline-offset-4 hover:decoration-white"
          >
            Impressum
          </a>.
        </p>
      </section>

      <!-- Navigation -->
      <nav aria-label="Footer Navigation">
        <h3 class="text-sm font-semibold uppercase tracking-wide text-white/90">
          Verein
        </h3>

        <ul class="mt-4 space-y-2 text-sm">
          {footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/65 transition hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Rechtliches / Kontakt -->
      <section>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-white/90">
          Rechtliches
        </h3>

        <ul class="mt-4 space-y-2 text-sm">
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/65 transition hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-6">
          <h3 class="text-sm font-semibold uppercase tracking-wide text-white/90">
            Folge uns
          </h3>

          <a
            href="https://www.instagram.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-block text-sm text-white/65 transition hover:text-white"
          >
            Instagram
          </a>
        </div>
      </section>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-10 flex flex-col gap-3 border-t border-white/10 pt-6 text-xs text-white/50 md:flex-row md:items-center md:justify-between">
      <p>
        © {currentYear} CMA e.V. Alle Rechte vorbehalten.
      </p>

      <p>
        Website für Calisthenics Movement Augsburg e.V.
      </p>
    </div>
  </div>
</footer>