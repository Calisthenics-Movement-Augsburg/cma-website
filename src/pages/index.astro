---
import Layout from '../layouts/Layout.astro';
import Background from '../components/Background.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import ContactForm from '../components/ContactForm.astro';
import settings from '../content/settings.json';

const groupfitnessDays = [
	{
		dateLabel: 'Montags',
		isToday: true,
		slots: [
			{ title: 'Gemeinsames Gruppentraining', time: '18:30 - 20:15 Uhr', trainer: 'Tobi, die Maus & Team', booked: 12, max: 20 },
		],
	},
	{
		dateLabel: 'Dienstags',
		isToday: false,
		slots: [{ title: 'Freies Static Training', time: '17:00 - 20:00 Uhr', trainer: 'Lennardo van de Leevar', booked: 4, max: 10 }],
	},
	{
		dateLabel: 'Mittwochs',
		isToday: false,
		slots: [
			{ title: 'Gemeinsames Gruppentraining', time: '18:30 - 20:15 Uhr', trainer: 'Tobi, die Maus & Team', booked: 8, max: 20 },
		],
	},
	{
		dateLabel: 'Donnerstags',
		isToday: false,
		slots: [{ title: 'Freies Static Training', time: '17:00 - 20:00 Uhr', trainer: 'Lennardo van de Leevar', booked: 3, max: 10 }],
	},
	{
		dateLabel: 'Freitags',
		isToday: false,
		slots: [
			{ title: 'Gemeinsames Gruppentraining', time: '18:30 - 20:15 Uhr', trainer: 'Tobi, die Maus & Team', booked: 9, max: 20 },
		],
	},
];

const pricingPlans = [
	{
		name: 'EINSTIEG.',
		tagline: 'Dabei sein, auch mit kleinem Budget',
		description: 'Für alle, die mittrainieren möchten, aber aktuell wenig finanziellen Spielraum haben.',
		features: ['Nutzung der Halle bis zu 1× pro Woche', 'Teilnahme an offenen Trainingseinheiten'],
		options: [
			{ price: '5', cents: '00' }
		],
	},	{
		name: 'BASIC.',
		tagline: 'Unsere Empfehlung',
		description: 'Der Standardbeitrag hilft uns, den laufenden Vereinsbetrieb verlässlich zu finanzieren.',
		features: ['Nutzung der Halle bis zu 3× pro Woche', 'Teilnahme an allen regulären Trainingszeiten', 'Mitwirkungsmöglichkeit bei internen Trainingsformaten'],
		options: [
			{ price: '20', cents: '00' }
		],
	},
];



const galleryImages = [
	{ src: '/gallery/training-0.jpg', alt: 'Athlet beim Handstandtraining im CMA Augsburg' },
	{ src: '/gallery/training-3.jpg', alt: 'Static-Training an Parallettes und Stangen' },
	{ src: '/gallery/training-4.jpg', alt: 'Calisthenics Gruppentraining im CMA Augsburg' },
	{ src: '/gallery/training-1.jpg', alt: 'Athlet beim Handstandtraining im CMA Augsburg' },
	{ src: '/gallery/training-2.jpg', alt: 'Calisthenics Gruppentraining im CMA Augsburg' },
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout title="Cali Fitness | Premium Gym">
	<Background />
	<header
	  id="site-header"
	  class="fixed top-0 w-full z-50 flex justify-between items-center px-8 py-4 border-b border-transparent bg-transparent transition-all duration-300"
	>
	  <div class="text-2xl font-black text-white drop-shadow-md">Calisthenics Movement <span class="text-brand">Augsburg</span></div>
	  <div class="flex items-center gap-6">
		<nav class="hidden md:block">
		  <ul class="flex gap-6 uppercase font-bold text-sm text-white drop-shadow-md">
			<li><a href="#home" class="hover:text-brand">Home</a></li>
			<li><a href="#image-gallery" class="hover:text-brand">Training</a></li>
			<li><a href="#trainings-timetable" class="hover:text-brand">Trainingszeiten</a></li>
			<li><a href="#tarife" class="hover:text-brand">Kosten</a></li>
			<li><a href="#contact" class="hover:text-brand">Kontakt</a></li>
			<li><a href="/team" class="hover:text-brand">Team</a></li>
			<li><a href="/downloads" class="hover:text-brand">Downloads</a></li>
		  </ul>
		</nav>
		<ThemeToggle />
	  </div>
	</header>
  
	<main>
	  <section id="home" class="relative min-h-screen h-[100svh] w-full overflow-hidden flex items-center justify-center">
		<div
		  class="hero-media absolute inset-0 z-0 bg-cover bg-center bg-no-repeat"
		  style="background-image:url('https://www.fitnesscenter-california.at/wp-content/uploads/2025/12/Hero-Gym-2025-Thumbnail.webp')"
		  role="img"
		  aria-label="Fitnesscenter California hero background"
		></div>
		<video
		  autoplay
		  muted
		  loop
		  playsinline
		  preload="auto"
		  class="hero-media absolute inset-0 z-10 hidden h-full w-full object-cover md:block"
		  poster="https://www.fitnesscenter-california.at/wp-content/uploads/2025/12/Hero-Gym-2025-Thumbnail.webp"
		  aria-hidden="true"
		>
		  <source src={settings.videoUrl} type="video/mp4" />
		</video>
		<div class="hero-overlay absolute inset-0 z-20 bg-[rgba(25,25,25,0.58)] md:bg-[rgba(25,25,25,0.50)] lg:bg-[rgba(25,25,25,0.42)]"></div>

		<div class="relative z-30 flex flex-col items-center justify-center px-4 text-center">
		  <img
			src="/logo.png"
			alt="Calisthenics Movement Augsburg"
			width="300"
			height="300"
			loading="lazy"
			decoding="async"
			class="w-[180px] md:w-[220px] lg:w-[300px] animate-hero-logo-in"
		  />
		</div>
	  </section>

	  <section id="hero" class="relative isolate overflow-hidden py-20 md:py-28">
		<div
		  class="absolute inset-0 -z-20 bg-cover bg-center bg-no-repeat"
		  style="background-image:url('https://www.fitnesscenter-california.at/wp-content/uploads/2026/04/Groupfitness-Timetable-Background.png')"
		  role="img"
		  aria-label="hero background"
		></div>
		<div class="absolute inset-0 -z-10 bg-white/70 dark:bg-black/60"></div>

		<div class="mx-auto w-full max-w-[1600px] px-4 sm:px-6 lg:px-10 text-gray-900 dark:text-white">
			<h2 class="text-center text-4xl md:text-5xl font-bold">Calisthenics Movement <span class="text-brand">Augsburg</span></h2>
			<div class="mx-auto mt-4 h-1.5 w-28 bg-brand"></div>

			<div class="mx-auto mt-8 max-w-3xl text-center md:mt-10 lg:max-w-4xl">
				<p class="text-xl text-brand-muted font-bold leading-snug tracking-tight text-balance md:text-2xl lg:text-3xl">
					Wir trainieren Calisthenics, Körpergewichtskraft, Skillarbeit und Beweglichkeit
				</p>
				<p class="hero-intro-sub mt-3 text-sm leading-relaxed text-balance opacity-80 md:text-base lg:text-lg">
					Gemeinsam, strukturiert und unabhängig vom aktuellen Leistungsstand.
				</p>
			</div>
		</div>
	  </section>

	  <section id="image-gallery" class="relative isolate overflow-hidden py-20 md:py-28">
		<div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-10">
			<div class="mb-10 text-center">
				<h2 class="text-4xl font-bold md:text-5xl">Einblicke ins Training</h2>
				<div class="mx-auto mt-4 h-1.5 w-28 bg-brand"></div>
			</div>
	
			<div
				id="gallery-carousel"
				class="group relative overflow-hidden rounded-3xl border border-gray-200 bg-black shadow-2xl dark:border-white/15"
				aria-roledescription="carousel"
				aria-label="Trainingsbilder"
			>
				<div class="relative h-[280px] sm:h-[420px] md:h-[560px]">
					{
						galleryImages.map((image, index) => (
							<div
								class:list={[
									'gallery-slide absolute inset-0 transition-opacity duration-500 ease-out',
									index === 0 ? 'opacity-100' : 'pointer-events-none opacity-0',
								]}
								data-gallery-slide
								aria-hidden={index === 0 ? 'false' : 'true'}
							>
								<img
									src={image.src}
									alt={image.alt}
									loading={index === 0 ? 'eager' : 'lazy'}
									decoding="async"
									class="h-full w-full object-cover"
								/>
								<div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-black/20"></div>
							</div>
						))
					}
				</div>
	
				<button
					type="button"
					class="absolute left-4 top-1/2 z-20 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur transition hover:bg-brand focus:outline-none focus:ring-4 focus:ring-white/50 md:left-6"
					data-gallery-prev
					aria-label="Vorheriges Bild"
				>
					<svg class="h-6 w-6" aria-hidden="true" viewBox="0 0 24 24" fill="none">
						<path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
	
				<button
					type="button"
					class="absolute right-4 top-1/2 z-20 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white backdrop-blur transition hover:bg-brand focus:outline-none focus:ring-4 focus:ring-white/50 md:right-6"
					data-gallery-next
					aria-label="Nächstes Bild"
				>
					<svg class="h-6 w-6" aria-hidden="true" viewBox="0 0 24 24" fill="none">
						<path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
	
				<div class="absolute bottom-5 left-1/2 z-20 flex -translate-x-1/2 gap-2">
					{
						galleryImages.map((_, index) => (
							<button
								type="button"
								class:list={[
									'gallery-dot h-2.5 rounded-full transition-all',
									index === 0 ? 'w-8 bg-brand' : 'w-2.5 bg-white/60 hover:bg-white',
								]}
								data-gallery-dot={index}
								aria-label={`Bild ${index + 1} anzeigen`}
								aria-current={index === 0 ? 'true' : 'false'}
							/>
						))
					}
				</div>
			</div>
		</div>
	</section>


	<section id="training-ablauf" class="relative isolate overflow-hidden py-20 md:py-28">
		<!-- <div
			class="absolute inset-0 -z-20 bg-cover bg-center bg-no-repeat"
			style="background-image:url('https://www.fitnesscenter-california.at/wp-content/uploads/2026/04/Groupfitness-Timetable-Background.png')"
			role="img"
			aria-label="Training background"
		></div> -->
		<div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-10"></div>
		<!-- <div class="absolute inset-0 -z-10 bg-white/75 dark:bg-black/65"></div> -->
	
		<div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-10 text-gray-900 dark:text-white">
			<div class="text-center">
				<h2 class="text-4xl font-bold md:text-5xl">Was trainieren wir?</h2>
				<div class="mx-auto mt-4 h-1.5 w-28 bg-brand"></div>
				<p class="mx-auto mt-6 max-w-3xl text-base leading-relaxed opacity-85 md:text-lg">
					Bei uns trainierst du Calisthenics, Körpergewichtskraft, Skills und Beweglichkeit.
					Der Fokus liegt auf sauberer Technik, sinnvollen Progressionen und langfristigem Aufbau.
				</p>
			</div>
	
			<div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
				<article class="training-info-card rounded-2xl border p-6">
					<h3 class="text-2xl font-extrabold">Basics</h3>
					<p class="mt-3 text-sm leading-relaxed opacity-85">
						Klimmzüge, Liegestütze, Dips, Core und grundlegende Körperspannung.
					</p>
				</article>
	
				<article class="training-info-card rounded-2xl border p-6">
					<h3 class="text-2xl font-extrabold">Skills</h3>
					<p class="mt-3 text-sm leading-relaxed opacity-85">
						Handstand, Muscle-Up, Front Lever, Planche und Human Flag.
					</p>
				</article>
	
				<article class="training-info-card rounded-2xl border p-6">
					<h3 class="text-2xl font-extrabold">Mobility</h3>
					<p class="mt-3 text-sm leading-relaxed opacity-85">
						Schulter, Hüfte, Pancake, aktive Beweglichkeit und kontrollierte Endpositionen.
					</p>
				</article>
	
				<article class="training-info-card rounded-2xl border p-6">
					<h3 class="text-2xl font-extrabold">Kraft</h3>
					<p class="mt-3 text-sm leading-relaxed opacity-85">
						Saubere Technik, passende Progressionen und nachhaltiger Kraftaufbau.
					</p>
				</article>
			</div>
	
			<div class="mt-14 grid gap-8 lg:grid-cols-2">
				<article class="training-info-card rounded-2xl border p-6 md:p-8">
					<h3 class="text-3xl font-extrabold">Für wen ist das Training geeignet?</h3>
					<p class="mt-5 text-base leading-relaxed opacity-90">
						Du musst keine Klimmzüge können, um bei uns anzufangen. Wir arbeiten mit Progressionen,
						sodass Anfänger und Fortgeschrittene im selben Training sinnvoll trainieren können.
					</p>
				</article>
	
				<article class="training-info-card rounded-2xl border p-6 md:p-8">
					<h3 class="text-3xl font-extrabold">Was soll man mitbringen?</h3>
					<ul class="mt-5 grid gap-3 text-base opacity-90">
						<li class="flex gap-3">
							<span class="text-brand font-black">•</span>
							<span>Sportkleidung</span>
						</li>
						<li class="flex gap-3">
							<span class="text-brand font-black">•</span>
							<span>Wasser</span>
						</li>
						<li class="flex gap-3">
							<span class="text-brand font-black">•</span>
							<span>Handtuch</span>
						</li>
						<li class="flex gap-3">
							<span class="text-brand font-black">•</span>
							<span>Saubere Hallenschuhe</span>
						</li>
						<li class="flex gap-3">
							<span class="text-brand font-black">•</span>
							<span>Keine spezielle Ausrüstung nötig</span>
						</li>
					</ul>
				</article>
			</div>
	
			<article class="training-info-card mt-8 rounded-2xl border p-6 md:p-8">
				<div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
					<div>
						<h3 class="text-3xl font-extrabold">Trainingsort</h3>
	
						<div class="mt-5 space-y-4 text-base leading-relaxed opacity-90">
							<p>
								<strong>Adresse:</strong><br />
								<!-- TODO: echte Adresse einsetzen -->
								Bla Bla Bla Musterstraße Bla Bla
							</p>
	
							<p>
								<strong>Zugang:</strong><br />
								<!-- TODO: Zugangshinweis anpassen -->
								Bla Bla Bla Bla Bla Bla Bla
							</p>
	
							<p>
								<strong>Parken / ÖPNV:</strong><br />
								<!-- TODO: echte Infos ergänzen -->
								Parkmöglichkeiten und ÖPNV-Anbindung ergänzen wir hier noch.
							</p>
						</div>
	
						<div class="mt-6 flex flex-wrap gap-4">
							<a
								class="inline-flex items-center rounded-full bg-brand px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-brand-muted"
								href="https://www.google.com/maps"
								target="_blank"
								rel="noreferrer"
							>
								Auf Google Maps öffnen
							</a>
						</div>
					</div>
	
					<div class="overflow-hidden rounded-2xl border border-gray-200 bg-gray-100 dark:border-white/15 dark:bg-white/5">
						<a
							href="https://www.google.com/maps"
							target="_blank"
							rel="noreferrer"
							class="flex aspect-[4/3] items-center justify-center p-8 text-center transition hover:bg-black/5 dark:hover:bg-white/5"
						>
							<div>
								<div class="text-5xl">📍</div>
								<p class="mt-4 text-lg font-bold">Karte / Maps-Link</p>
								<p class="mt-2 text-sm opacity-75">
									TODO: ggf Maps Link einfügen, falls wir das wirklich wollen
								</p>
							</div>
						</a>
					</div>
				</div>
			</article>
	
			<div class="mt-14 text-center">
				<h3 class="text-3xl font-extrabold">Du möchtest mittrainieren?</h3>
				<p class="mt-3 text-base opacity-85 md:text-lg">
					Dann melde dich für ein Probetraining an.
				</p>
	
				<a
					class="mt-6 inline-flex items-center rounded-full bg-brand px-8 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-brand-muted"
					href="#contact"
				>
					Probetraining anfragen
				</a>
			</div>
		</div>
	</section>



	  <section
		id="trainings-timetable"
		class="relative isolate overflow-hidden py-20 md:py-28"
	  >
		<div
		  class="absolute inset-0 -z-20 bg-cover bg-center bg-no-repeat"
		  style="background-image:url('https://www.fitnesscenter-california.at/wp-content/uploads/2026/04/Groupfitness-Timetable-Background.png')"
		  role="img"
		  aria-label="trainings timetable background"
		></div>
		<div class="absolute inset-0 -z-10 bg-white/70 dark:bg-black/60"></div>

		<div class="mx-auto w-full max-w-[1600px] px-4 sm:px-6 lg:px-10 text-gray-900 dark:text-white">
		  <h2 class="text-center text-4xl md:text-5xl font-bold">Trainingszeiten</h2>
		  <div class="mx-auto mt-4 h-1.5 w-28 bg-brand"></div>

		  <div class="mt-10">
			<!-- <div class="mb-4 flex items-center justify-center gap-3">
			  <button class="ml-nav-btn" id="ml-prev" type="button" disabled>Zuruck</button>
			  <button class="ml-nav-btn" id="ml-next" type="button">Weiter</button>
			</div> -->

			<div id="ml-slider" class="ml-slider-cols">
				{
					groupfitnessDays.map((day) => (
						<article class="ml-day-col">
							<header class="ml-day-header">
								<span class:list={['ml-day-title', day.isToday && 'ml-today']}>{day.dateLabel}</span>
							</header>
							<div class="ml-day-slots">
								{day.slots.map((slot) => {
									const percent = Math.round((slot.booked / slot.max) * 100);
									const freeSpots = slot.max - slot.booked;
									const warnProgress = percent >= 60;

									return (
										<div class="ml-card">
											<div class="ml-card-title">{slot.title}</div>
											<div class="ml-meta-row"><strong>{slot.time}</strong></div>
											<div class="ml-meta-row"><strong>{slot.trainer}</strong></div>
											<div class="ml-progress-labels">
												<span>{slot.booked} / {slot.max} Anmeldungen</span>
												<span>{percent}%</span>
											</div>
											<div class="ml-progress-bar-bg">
												<div class:list={['ml-progress-bar-fill', warnProgress && 'ml-progress-warn']} style={`width:${percent}%`}></div>
											</div>
											<span class="ml-badge ml-badge-free">{freeSpots} Plätze frei</span>
										</div>
									);
								})}
							</div>
						</article>
					))
				}
			</div>
		  </div>

		  <div class="mt-10 flex justify-center">
			<a
			  class="inline-flex items-center rounded-full bg-brand px-8 py-3 text-sm font-bold uppercase tracking-wide transition hover:bg-brand-muted"

			  href="#contact"
			>
			  Zum Probetraining
			</a>
		  </div>
		</div>
	  </section>

	  <section id="tarife" class="py-20 md:py-30 px-4">
		<div class="mx-auto max-w-6xl">
			<h2 class="text-center text-4xl md:text-5xl font-bold">Mitgliedschaft & Beiträge</h2>
			<div class="mx-auto mt-4 h-1.5 w-28 bg-brand"></div>

			<div class="mt-12 text-md">
				<p>
				Wir möchten Training möglichst zugänglich halten und finanzieren den Verein deshalb über ein solidarisches Beitragsmodell.
			</p><p>
Die Mitgliedschaft ist bereits ab 5 € monatlich möglich. Unser empfohlener Standardbeitrag liegt bei 20 € monatlich. Wer den Verein stärker unterstützen möchte, kann freiwillig eine höhere Beitragsstufe wählen.
</p><p>
Deine Beitragsstufe kannst du monatlich an deine aktuelle Situation anpassen. Wenn du für längere Zeit nicht teilnehmen kannst, zum Beispiel wegen 'nem Auslandssemester, längerer Reise oder persönlicher Umstände, kannst du deine Mitgliedschaft natürlich pausieren.
				</p>
			</div>
			

			<div class="mt-12 grid gap-7 lg:grid-cols-2">
				{
					pricingPlans.map((plan) => (
						<article class="pricing-card rounded-2xl border p-6 md:p-9">
							<h3 class="text-3xl md:text-4xl font-extrabold tracking-tight">{plan.name}</h3>
							<h5 class="text-xl text-brand-muted md:text-2xl font-bold tracking-tight">{plan.tagline}</h4>
							<div class="mt-5 grid gap-3 sm:grid-cols-2">
								{plan.features.map((feature) => (
									<div class="flex items-center gap-2 text-sm font-semibold">
										<span class="pricing-check">•</span>
										<span>{feature}</span>
									</div>
								))}
							</div>
							<div class="mt-9 flex flex-wrap justify-center gap-4">
								{plan.options.map((option) => (
									<div class="pricing-option w-full max-w-xs sm:max-w-sm rounded-xl border p-4 md:p-5 text-center">
										
										<div class="mb-4">
											<span class="text-sm font-semibold uppercase tracking-wide opacity-75">EUR</span>
											<span class="ml-1 text-4xl leading-none font-extrabold">{option.price}</span>
											<span class="align-top text-base font-bold">,{option.cents}</span>
											<span class="ml-1 text-xs font-semibold uppercase tracking-wide">mtl.</span>
										</div>
										<a
											class:list={[
												'inline-flex w-full items-center justify-center rounded-full px-4 py-2 text-xs font-bold uppercase tracking-wide transition',
												'bg-brand text-white hover:bg-brand-muted',
											]}
											title="Anmelden"
											href="#contact"
										>
											Auf geht's
										</a>
									</div>
								))}
							</div>
						</article>
