---
import Layout from '../layouts/Layout.astro';
import Background from '../components/Background.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Intro from '../components/Intro.astro';
import Gallery from '../components/Gallery.astro';
import TrainingInfo from '../components/TrainingInfo.astro';
import Timetable from '../components/Timetable.astro';
import Pricing from '../components/Pricing.astro';
import TrialTraining from '../components/TrialTraining.astro';
import Contact from '../components/Contact.astro';

import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type PricingEntry = CollectionEntry<'pricing'>;

const pricingItems = ((await getCollection('pricing')) as PricingEntry[]).sort(
	(a, b) => a.data.order - b.data.order
);

const hero = await getEntry('homeHero', 'index');

if (!hero) {
	throw new Error('Missing hero content: src/content/home-hero/index.md');
}

const pricingPage = await getEntry('pricingPage', 'index');

if (!pricingPage) {
	throw new Error('Missing pricing page content: src/content/pricing-page/index.md');
}

---

<Layout title="Calisthenics Movement Augsburg">
	<Background />
	<Header />

	<main>
		<Hero content={hero.data} />
		<Intro />
		<Gallery />
		<TrainingInfo />
		<Timetable />
		<Pricing content={pricingPage.data} items={pricingItems} />
		<TrialTraining />
		<Contact />
	</main>
</Layout>
