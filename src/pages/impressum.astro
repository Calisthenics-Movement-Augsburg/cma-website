---
import Layout from '../layouts/Layout.astro';
import SmallHeader from '../components/SmallHeader.astro';
import SectionBackground from '../components/SectionBackground.astro';
import { getEntry, render } from 'astro:content';

const impressumEntry = await getEntry('impressum', 'index');

if (!impressumEntry) {
	throw new Error('Missing impressum content: src/content/impressum/index.md');
}

const sharedSectionBackground = await getEntry('sharedSectionBackground', 'index');

if (!sharedSectionBackground) {
	throw new Error('Missing shared section background content: src/content/shared-section-background/index.md');
}

const { Content } = await render(impressumEntry);

const content = impressumEntry.data;
const backgroundImage = sharedSectionBackground.data.image;

const buttonClass = (variant: 'primary' | 'secondary') =>
	variant === 'primary'
		? 'inline-flex items-center rounded-full bg-brand px-8 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-brand-muted'
		: 'inline-flex items-center rounded-full border border-current px-8 py-3 text-sm font-bold uppercase tracking-wide transition hover:bg-black/5 dark:hover:bg-white/10';
---

<Layout title={content.layoutTitle}>
	<SmallHeader currentPage="impressum" />

	<main>
		<section class="l-section custom relative min-h-[34vh] md:min-h-[40vh] flex items-center justify-center overflow-hidden pt-14 md:pt-16">
			<SectionBackground
				image={backgroundImage}
				overlayClass="bg-white/70 md:bg-white/60 lg:bg-white/50 dark:bg-black/45"
			/>

			<h1 class="text-dark text-4xl md:text-6xl font-black tracking-tight drop-shadow-xl dark:text-white/95">
				{content.heroTitle}
			</h1>
		</section>

		<section class="py-14 md:py-22 px-4">
			<div class="mx-auto max-w-[920px]">
				<div class="mx-auto mt-3 h-1.5 w-24 md:w-28 bg-brand"></div>

				<p class="mx-auto mt-8 max-w-3xl text-center text-sm md:text-base opacity-85">
					{content.intro}
				</p>

				<div class="impressum-card impressum-content mt-10 md:mt-12">
					<Content />
				</div>

				<div class="mt-10 md:mt-12 flex flex-wrap justify-center gap-4">
					{content.buttons.map((button) => (
						<a class={buttonClass(button.variant)} href={button.href}>
							{button.label}
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.l-section {
		padding-left: 2.5rem;
		padding-right: 2.5rem;
	}

	.l-section.custom {
		padding-top: var(--section-custom-padding, 5vmax);
		padding-bottom: var(--section-custom-padding, 5vmax);
	}

	.impressum-card {
		border-radius: 1rem;
		border: 1px solid rgba(17, 24, 39, 0.14);
		background: rgba(255, 255, 255, 0.78);
		box-shadow: 0 18px 45px -28px rgba(17, 24, 39, 0.35);
		overflow: hidden;
	}

	:global(.dark) .impressum-card {
		background: rgba(255, 255, 255, 0.06);
		border-color: rgba(255, 255, 255, 0.15);
	}

	:global(.impressum-content h2) {
		margin: 0;
		padding: 1.35rem 1.5rem 0;
		font-size: 0.9rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	:global(.impressum-content h2:not(:first-child)) {
		border-top: 1px solid rgba(17, 24, 39, 0.1);
	}

	:global(.dark .impressum-content h2:not(:first-child)) {
		border-top-color: rgba(255, 255, 255, 0.12);
	}

	:global(.impressum-content p) {
		margin: 0;
		padding: 0.65rem 1.5rem 1.35rem;
		font-size: 0.95rem;
		line-height: 1.7;
		opacity: 0.86;
	}

	:global(.impressum-content h2 + p) {
		padding-top: 0.75rem;
	}

	:global(.impressum-content p + p) {
		padding-top: 0;
	}

	:global(.impressum-content a) {
		color: var(--color-brand);
		font-weight: 700;
		text-decoration: underline;
		text-underline-offset: 0.25rem;
		text-decoration-thickness: 1px;
	}

	:global(.impressum-content a:hover) {
		color: var(--color-brand-muted);
	}

	:global(.impressum-content blockquote) {
		margin: 0 1.5rem 1.35rem;
		border-left: 4px solid var(--color-brand);
		padding-left: 0.9rem;
		font-size: 0.85rem;
		line-height: 1.7;
		opacity: 0.72;
	}

	:global(.impressum-content blockquote p) {
		padding: 0;
		font-size: inherit;
		opacity: 1;
	}

	@media (max-width: 767px) {
		.l-section {
			padding-left: 1.25rem;
			padding-right: 1.25rem;
		}

		.impressum-card {
			background: transparent;
			border: none;
			box-shadow: none;
			overflow: visible;
		}

		:global(.impressum-content h2) {
			margin-top: 1rem;
			border: 1px solid rgba(17, 24, 39, 0.14);
			border-bottom: none;
			border-radius: 1rem 1rem 0 0;
			background: rgba(255, 255, 255, 0.78);
			padding: 1.1rem 1rem 0.25rem;
		}

		:global(.dark .impressum-content h2) {
			background: rgba(255, 255, 255, 0.06);
			border-color: rgba(255, 255, 255, 0.15);
		}

		:global(.impressum-content h2:not(:first-child)) {
			border-top: 1px solid rgba(17, 24, 39, 0.14);
		}

		:global(.impressum-content p),
		:global(.impressum-content blockquote) {
			margin: 0;
			border-left: none;
			border-right: 1px solid rgba(17, 24, 39, 0.14);
			border-left: 1px solid rgba(17, 24, 39, 0.14);
			background: rgba(255, 255, 255, 0.78);
			padding: 0.85rem 1rem;
			font-size: 0.9rem;
		}

		:global(.dark .impressum-content p),
		:global(.dark .impressum-content blockquote) {
			background: rgba(255, 255, 255, 0.06);
			border-color: rgba(255, 255, 255, 0.15);
		}

		:global(.impressum-content h2 + p),
		:global(.impressum-content h2 + blockquote) {
			padding-top: 0.75rem;
		}

		:global(.impressum-content h2 ~ p:last-child),
		:global(.impressum-content h2 ~ blockquote:last-child) {
			border-radius: 0 0 1rem 1rem;
		}
	}
</style>