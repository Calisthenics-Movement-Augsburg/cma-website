---
import Layout from '../layouts/Layout.astro';
import Background from '../components/Background.astro';
import SmallHeader from '../components/SmallHeader.astro';
import SectionBackground from '../components/SectionBackground.astro';
import { getEntry } from 'astro:content';

const teamPage = await getEntry('team', 'index');

if (!teamPage) {
	throw new Error('Missing team content: src/content/team/index.md');
}

const sharedSectionBackground = await getEntry('sharedSectionBackground', 'index');

if (!sharedSectionBackground) {
	throw new Error('Missing shared section background content: src/content/shared-section-background/index.md');
}

const content = teamPage.data;
const backgroundImage = sharedSectionBackground.data.image;
---

<Layout title={content.layoutTitle}>
	<Background />
	<SmallHeader currentPage="team" />

	<main>
		<section class="l-section custom relative min-h-[34vh] md:min-h-[40vh] flex items-center justify-center overflow-hidden pt-14 md:pt-16">
			<SectionBackground
				image={backgroundImage}
				overlayClass="bg-white/70 md:bg-white/60 lg:bg-white/50 dark:bg-black/45"
			/>

			<h1 class="text-dark text-4xl md:text-6xl font-black tracking-tight drop-shadow-xl dark:text-white/95">
				{content.heroTitle}
			</h1>
		</section>

		<section class="py-14 md:py-22 px-4">
			<div class="mx-auto max-w-[1120px]">
				<h2 class="text-center text-3xl md:text-5xl font-bold dark:text-white/95">
					{content.sectionTitle}
				</h2>

				<div class="mx-auto mt-3 h-1.5 w-24 md:w-28 bg-brand"></div>

				<div class="team-grid mt-10 md:mt-12 grid">
					{
						content.members.map((member) => (
							<article class="team-card">
								<img
									src={member.image}
									alt={member.alt}
									loading="lazy"
									decoding="async"
									class="w-full object-cover object-center"
									style="aspect-ratio: 2 / 3;"
								/>

								<div class="pt-3 md:pt-4 text-center">
									<h3 class="text-[1.55rem] md:text-2xl font-bold leading-tight">
										{member.name}
									</h3>

									<p class="mt-1 text-[0.92rem] opacity-70">
										{member.role}
									</p>
								</div>
							</article>
						))
					}
				</div>

				<!-- <div class="mt-10 md:mt-12 flex justify-center">
					<a
						class="inline-flex items-center rounded-full bg-brand px-8 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-brand-muted"
						title={content.cta.title ?? content.cta.label}
						rel={content.cta.external ? 'nofollow noreferrer' : undefined}
						target={content.cta.external ? '_blank' : undefined}
						href={content.cta.href}
					>
						{content.cta.label}
					</a>
				</div> -->
			</div>
		</section>
	</main>
</Layout>

<style>
	.team-card {
		text-align: center;
		position: relative;
		z-index: 1;
		max-width: 25rem;
		margin-left: auto;
		margin-right: auto;
		transition: transform 220ms ease;
	}

	.l-section {
		padding-left: 2.5rem;
		padding-right: 2.5rem;
	}

	.l-section.custom {
		padding-top: var(--section-custom-padding, 5vmax);
		padding-bottom: var(--section-custom-padding, 5vmax);
	}

	.team-card:hover {
		transform: translateY(-4px);
	}

	.team-grid {
		gap: 3rem;
		grid-template-columns: 1fr;
	}

	@media (min-width: 900px) {
		.team-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>