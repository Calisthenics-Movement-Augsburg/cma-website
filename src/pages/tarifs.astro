---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Background from '../components/Background.astro';

const membershipTiers = [
	{
		tier: 'Sozial',
		fee: '5 € / Monat',
		description: 'Wenn das Budget gerade sehr knapp ist',
		recommended: false,
	},
	{
		tier: 'Einstieg',
		fee: '10 € / Monat',
		description: 'Wenn du mittrainieren möchtest, aber wenig finanziellen Spielraum hast',
		recommended: false,
	},
	{
		tier: 'Standard',
		fee: '20 € / Monat',
		description: 'Empfohlener regulärer Vereinsbeitrag',
		recommended: true,
	},
	{
		tier: 'Support',
		fee: '30 € / Monat',
		description: 'Wenn du den Verein zusätzlich unterstützen möchtest',
		recommended: false,
	},
	{
		tier: 'Förderstufe',
		fee: '40 € / Monat',
		description: 'Wenn du bewusst mehr beitragen möchtest',
		recommended: false,
	},
	{
		tier: 'Starke Förderung',
		fee: '50 € / Monat',
		description: 'Wenn du den Verein besonders stark unterstützen möchtest',
		recommended: false,
	},
];
---

<Layout title="Beitragsstufen | Calisthenics Movement Augsburg">
	<header
		id="tarifs-header"
		class="fixed top-0 w-full z-50 border-b border-white/10 bg-black/55 backdrop-blur-md"
	>
		<div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-3 md:px-6">
			<a href="/" aria-label="Calisthenics Movement Augsburg">
				<img
					src="/logo.png"
					alt="Calisthenics Movement Augsburg"
					loading="lazy"
					decoding="async"
					class="h-9 w-9 md:h-10 md:w-10"
				/>
			</a>
			<nav class="hidden lg:block">
				<ul class="flex gap-7 uppercase font-bold text-sm text-white/95">
					<li><a href="/#tarife" class="text-brand">Tarife</a></li>
					<li><a href="/#trainings-timetable" class="hover:text-brand">Training</a></li>
					<li><a href="/team" class="hover:text-brand">Team</a></li>
					<li><a href="/#contact" class="hover:text-brand">Kontakt</a></li>
				</ul>
			</nav>
			<div class="flex items-center gap-3">
				<a
					class="hidden md:inline-flex items-center rounded-full bg-brand px-5 py-2 text-xs font-bold uppercase tracking-wide text-white transition hover:bg-brand-muted"
					href="/#contact"
				>
					Zum Probetraining
				</a>
				<ThemeToggle />
			</div>
		</div>
	</header>

	<main>
		<Background />
		<section class="l-section custom relative min-h-[34vh] md:min-h-[40vh] flex items-center justify-center overflow-hidden pt-14 md:pt-16">
			<div
				class="absolute inset-0 -z-20 bg-cover bg-center bg-no-repeat"
				style="background-image:url('https://www.fitnesscenter-california.at/wp-content/uploads/2023/02/banner-breadcrumb.jpeg')"
				role="img"
				aria-label="Beitragsstufen banner"
			></div>
			<div class="absolute inset-0 -z-10 bg-white/70 md:bg-white/60 lg:bg-white/50 dark:bg-black/45"></div>
			<h1 class="text-dark text-4xl md:text-6xl font-black tracking-tight drop-shadow-xl dark:text-white/95">
				Beitragsstufen
			</h1>
		</section>

		<section class="py-14 md:py-22 px-4">
			<div class="mx-auto max-w-[1120px]">
				<h2 class="text-center text-3xl md:text-5xl font-bold dark:text-white/95">Solidarisches Beitragsmodell</h2>
				<div class="mx-auto mt-3 h-1.5 w-24 md:w-28 bg-brand"></div>

				<p class="mx-auto mt-8 max-w-3xl text-center text-sm md:text-base opacity-85">
					Wähle die Beitragsstufe, die zu deiner aktuellen Situation passt. Du kannst sie jederzeit anpassen.
				</p>

				<div class="tarifs-table-wrap mt-10 md:mt-12 overflow-x-auto">
					<table class="tarifs-table w-full min-w-[640px] border-collapse text-left">
						<thead>
							<tr>
								<th scope="col">Beitragsstufe</th>
								<th scope="col">Beitrag</th>
								<th scope="col">Für wen gedacht</th>
							</tr>
						</thead>
						<tbody>
							{
								membershipTiers.map((row) => (
									<tr class:list={[row.recommended && 'tarifs-row-recommended']}>
										<td data-label="Beitragsstufe">
											<span class="font-bold">{row.tier}</span>
											{row.recommended ? <span class="tarifs-badge">Empfohlen</span> : null}
										</td>
										<td data-label="Beitrag" class="font-semibold text-brand">{row.fee}</td>
										<td data-label="Für wen gedacht">{row.description}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>

				<div class="mt-10 md:mt-12 flex flex-wrap justify-center gap-4">
					<a
						class="inline-flex items-center rounded-full bg-brand px-8 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-brand-muted"
						href="/#contact"
					>
						Zum Probetraining
					</a>
					<a
						class="inline-flex items-center rounded-full border border-current px-8 py-3 text-sm font-bold uppercase tracking-wide transition hover:bg-black/5 dark:hover:bg-white/10"
						href="/#tarife"
					>
						Zurück zur Übersicht
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.l-section {
		padding-left: 2.5rem;
		padding-right: 2.5rem;
	}

	.l-section.custom {
		padding-top: var(--section-custom-padding, 5vmax);
		padding-bottom: var(--section-custom-padding, 5vmax);
	}

	.tarifs-table-wrap {
		border-radius: 1rem;
		border: 1px solid rgba(17, 24, 39, 0.14);
		background: rgba(255, 255, 255, 0.78);
		box-shadow: 0 18px 45px -28px rgba(17, 24, 39, 0.35);
	}

	:global(.dark) .tarifs-table-wrap {
		background: rgba(255, 255, 255, 0.06);
		border-color: rgba(255, 255, 255, 0.15);
	}

	.tarifs-table th,
	.tarifs-table td {
		padding: 1rem 1.25rem;
		border-bottom: 1px solid rgba(17, 24, 39, 0.1);
		vertical-align: top;
	}

	:global(.dark) .tarifs-table th,
	:global(.dark) .tarifs-table td {
		border-bottom-color: rgba(255, 255, 255, 0.12);
	}

	.tarifs-table thead th {
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		background: rgba(17, 24, 39, 0.04);
	}

	:global(.dark) .tarifs-table thead th {
		background: rgba(255, 255, 255, 0.06);
	}

	.tarifs-table tbody tr:last-child td {
		border-bottom: none;
	}

	.tarifs-row-recommended {
		background: rgba(188, 108, 255, 0.08);
	}

	:global(.dark) .tarifs-row-recommended {
		background: rgba(188, 108, 255, 0.12);
	}

	.tarifs-badge {
		display: inline-block;
		margin-left: 0.5rem;
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		background: var(--color-brand);
		color: #fff;
	}

	@media (max-width: 767px) {
		.tarifs-table-wrap {
			background: transparent;
			border: none;
			box-shadow: none;
			overflow-x: visible;
		}

		.tarifs-table,
		.tarifs-table thead,
		.tarifs-table tbody,
		.tarifs-table th,
		.tarifs-table td,
		.tarifs-table tr {
			display: block;
			width: 100%;
			min-width: 0;
		}

		.tarifs-table thead {
			display: none;
		}

		.tarifs-table tbody tr {
			margin-bottom: 1rem;
			border: 1px solid rgba(17, 24, 39, 0.14);
			border-radius: 1rem;
			background: rgba(255, 255, 255, 0.78);
			overflow: hidden;
		}

		:global(.dark) .tarifs-table tbody tr {
			background: rgba(255, 255, 255, 0.06);
			border-color: rgba(255, 255, 255, 0.15);
		}

		.tarifs-table td {
			display: grid;
			grid-template-columns: minmax(7rem, 38%) 1fr;
			gap: 0.5rem 1rem;
			border-bottom: 1px solid rgba(17, 24, 39, 0.08);
			padding: 0.85rem 1rem;
		}

		:global(.dark) .tarifs-table td {
			border-bottom-color: rgba(255, 255, 255, 0.1);
		}

		.tarifs-table td::before {
			content: attr(data-label);
			font-size: 0.72rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			opacity: 0.7;
		}

		.tarifs-table tbody tr:last-child td:last-child {
			border-bottom: none;
		}
	}
</style>
